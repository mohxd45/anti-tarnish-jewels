rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is admin in Firestore
    function isAdmin() {
      return request.auth != null && 
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public reads allowed for all images
    match /{allPaths=**} {
      allow read: if true;
    }

    // Product Images upload rule (only allow admin to upload product images)
    match /product-images/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Banner Images upload rule (only allow admin to upload banner images)
    match /banner-images/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Images upload rule (fallback for legacy or other uses)
    match /images/{imageName} {
      allow write: if isAdmin();
    }

    // Admin assets folder (strict admin write)
    match /admin/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Users personal uploads (e.g. reviews or profiles)
    match /users/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
