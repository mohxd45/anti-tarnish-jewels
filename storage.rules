rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function getRole() {
      return request.auth != null && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    function isAdmin() {
      let role = getRole();
      return role in ['owner', 'admin', 'owner_admin', 'partner_admin', 'developer_admin'];
    }
    function isStaff() {
      return getRole() == 'staff';
    }
    function isAnyAdminOrStaff() {
      return request.auth != null && (isAdmin() || isStaff());
    }

    // Secure Uploads for Images
    match /{folder}/{allPaths=**} {
      // Allow exact GET for public images. BLOCK public LIST.
      allow get: if folder in ['product-images', 'bundle-images', 'bundles', 'banner-images', 'category-images', 'categories'];
      allow list: if isAnyAdminOrStaff();
      
      // Update/Create strictly validates MIME type and file size
      allow create, update: if isAnyAdminOrStaff()
        && folder in ['product-images', 'bundle-images', 'bundles', 'banner-images', 'category-images', 'categories']
        && request.resource.contentType.matches('^image/(jpeg|png|webp)$')
        && request.resource.size < 10 * 1024 * 1024;
        
      // Delete does not have a request.resource payload, so we only check the folder access
      allow delete: if isAnyAdminOrStaff()
        && folder in ['product-images', 'bundle-images', 'bundles', 'banner-images', 'category-images', 'categories'];
    }
    
    // Block all other root level or random folder access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
