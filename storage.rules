rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is admin in Firestore
    function isAdmin() {
      return request.auth != null && 
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper to check if file is a valid image under 5MB
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    // Public reads allowed for all files by default
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false; // explicit fallback deny
    }

    // Product Images upload rule
    match /product-images/{allPaths=**} {
      allow write: if isAdmin() && isValidImage();
    }

    // Banner Images upload rule
    match /banner-images/{allPaths=**} {
      allow write: if isAdmin() && isValidImage();
    }

    // Images upload rule (fallback for legacy or other uses)
    match /images/{imageName} {
      allow write: if isAdmin() && isValidImage();
    }

    // Admin assets folder
    match /admin/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Users personal uploads (e.g. reviews or profiles)
    match /users/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId && isValidImage();
    }
  }
}
