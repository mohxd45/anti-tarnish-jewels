rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is admin in Firestore
    function isAdmin() {
      return request.auth != null && 
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Public reads allowed for all images
    match /{allPaths=**} {
      allow read: if true;
    }

    // Images upload rule (only allow authenticated users uploading images)
    match /images/{imageName} {
      allow write: if request.auth != null && (isAdmin() || request.resource.contentType.matches('image/.*'));
    }

    // Admin assets folder (strict admin write)
    match /admin/{allPaths=**} {
      allow write: if isAdmin();
    }

    // Users personal uploads (e.g. reviews or profiles)
    match /users/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
