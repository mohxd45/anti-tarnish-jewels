rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    
    function isAdmin() {
      let role = getRole();
      return role in ['owner', 'admin', 'owner_admin', 'partner_admin', 'developer_admin'];
    }

    function isDevAdmin() {
      return getRole() == 'developer_admin';
    }

    function isStaff() {
      return getRole() == 'staff';
    }

    function isAnyAdminOrStaff() {
      return request.auth != null && (isAdmin() || isStaff());
    }

    // Products
    match /products/{productId} {
      allow read: if true; 
      allow create, update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }

    // Bundles
    match /bundles/{bundleId} {
      allow read: if true;
      allow create, update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow create: if false; 
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || isAnyAdminOrStaff());
      allow update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }

    match /returnRequests/{docId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAnyAdminOrStaff());
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && !('approved' in request.resource.data)
        && !('rejected' in request.resource.data)
        && !('refunded' in request.resource.data)
        && !('adminNotes' in request.resource.data)
        && !('refundAmount' in request.resource.data);
      allow update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }

    match /publicTrackingOrders/{docId} {
      allow get: if true;
      allow list: if false;
      allow create: if false; 
      allow update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }

    match /orderLookups/{docId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }

    match /trackingMappings/{docId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAnyAdminOrStaff());
      
      allow create: if request.auth != null
        && request.auth.uid == userId
        && (!("uid" in request.resource.data) || request.resource.data.uid == request.auth.uid)
        && (!("email" in request.resource.data) || request.resource.data.email == request.auth.token.email)
        && request.resource.data.keys().hasOnly([
          "uid", "email", "name", "displayName", "role", "status", "dateJoined", "createdAt", 
          "lastLoginAt", "updatedAt", "provider", "loginMethod", "photoURL", 
          "phone", "phoneCountryCode", "phoneNumber", "phoneE164", "phoneClean", 
          "address", "addresses", "city", "state", "pincode"
        ])
        && (!("role" in request.resource.data) || request.resource.data.role == "customer")
        && (!("status" in request.resource.data) || request.resource.data.status == "active");

      allow update: if request.auth != null && (
        (
          request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "name", "displayName", "phone", "phoneCountryCode", "phoneNumber", 
            "phoneE164", "phoneClean", "photoURL", "address", "addresses", 
            "city", "state", "pincode", "updatedAt", "lastLoginAt"
          ])
        )
        || isAdmin()
      );
      
      allow delete: if isAdmin();
    }
    
    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }
    
    // Banners
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }
    
    // Coupons 
    match /coupons/{couponId} {
      allow read, create, update: if isAnyAdminOrStaff();
      allow delete: if isAdmin();
    }
    
    // Site configuration and UI settings (Public Read)
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAnyAdminOrStaff();
    }
    match /siteContent/{docId} {
      allow read: if true;
      allow write: if isAnyAdminOrStaff();
    }
    match /homepageSections/{docId} {
      allow read: if true;
      allow write: if isAnyAdminOrStaff();
    }
    match /seoSettings/{docId} {
      allow read: if true;
      allow write: if isAnyAdminOrStaff();
    }
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAnyAdminOrStaff();
    }
    match /announcementsList/{docId} {
      allow read: if true;
      allow write: if isAnyAdminOrStaff();
    }

    match /reviews/{docId} {
      allow read: if true;
      allow create, update, delete: if isAnyAdminOrStaff();
    }

    match /contactMessages/{docId} {
      allow create: if false; 
      allow read, update, delete: if isAnyAdminOrStaff();
    }

    match /auditLogs/{docId} {
      allow read: if isAdmin();
      allow create: if isAnyAdminOrStaff();
      allow update, delete: if isDevAdmin();
    }

    match /{document=**} {
      allow read, write: if request.auth != null && isDevAdmin();
    }
  }
}
